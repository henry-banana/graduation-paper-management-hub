{
  "name": "kltn-backend",
  "version": "0.1.0",
  "description": "HCM-UTE Graduation Management API",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/main",
    "seed": "ts-node --transpile-only scripts/seed.ts",
    "seed:sheets": "ts-node --transpile-only scripts/seed.ts",
    "seed:sheets:validate": "ts-node --transpile-only scripts/seed.ts --validate-only",
    "seed:sheets:reset": "ts-node --transpile-only scripts/seed.ts --reset",
    "seed:sheets:test-idempotent": "npm run seed:sheets && npm run seed:sheets && npm run seed:sheets:validate",
    "seed:sheets:reseed": "ts-node --transpile-only src/scripts/reseed-sheets.ts",
    "seed:sheets:rollback": "ts-node --transpile-only src/scripts/rollback-from-preview.ts",
    "import:sheets": "ts-node --transpile-only src/scripts/import-from-teacher-sheet.ts",
    "cleanup:sheets": "ts-node --transpile-only src/scripts/cleanup-old-sheets.ts",
    "inspect:sheets": "ts-node --transpile-only src/scripts/inspect-sheets.ts",
    "preview:sheets": "ts-node --transpile-only src/scripts/fetch-sheet-preview.ts",
    "backfill:sheets:v34": "ts-node --transpile-only src/tools/backfill-sheets-v34.ts",
    "sweep:api": "ts-node src/scripts/full-curl-sweep.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:smoke": "jest --config ./test/jest-e2e.json --runInBand --testPathPattern smoke.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "cache-manager": "^5.5.0",
    "chromium": "^3.0.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "docx": "^9.6.1",
    "docxtemplater": "^3.68.3",
    "googleapis": "^134.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.0",
    "pizzip": "^3.2.0",
    "puppeteer-core": "^24.40.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.37",
    "@types/passport-google-oauth20": "^2.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
