PORT=3001
NODE_ENV=development
MOCK_AUTH=true
ACCESS_LOG_ENABLED=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=change-this-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# In production this must point to your backend public callback URL (never localhost)
# Example: https://graduation-paper-management-hub.onrender.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
# Optional fallback for Render deployments when GOOGLE_CALLBACK_URL is not set
# Render usually injects this value automatically
RENDER_EXTERNAL_URL=

# Google Service Account (JSON format)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheets
GOOGLE_SHEETS_ID=your-spreadsheet-id

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Google Drive auth mode (auto|service_account|oauth_user)
# - auto: prefer OAuth user when refresh token is configured, else service account
# - service_account: force service account mode
# - oauth_user: force OAuth user mode
GOOGLE_DRIVE_AUTH_MODE=auto

# Optional OAuth user credentials for Drive upload (recommended for personal Gmail)
# Falls back to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET when omitted
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Cache / rate-limit store (optional)
REDIS_URL=redis://localhost:6379
