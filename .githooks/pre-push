#!/bin/sh

set -eu

if [ "${SKIP_PREPUSH_CHECKS:-0}" = "1" ]; then
  echo "[pre-push] Skipped by SKIP_PREPUSH_CHECKS=1"
  exit 0
fi

echo "[pre-push] Running backend checks..."
if [ -f "backend/package.json" ]; then
  npm --prefix backend run test -- --passWithNoTests
  npm --prefix backend run build
fi

echo "[pre-push] Running frontend checks..."
if [ -f "frontend/package.json" ]; then
  if [ -f "frontend/.eslintrc" ] || [ -f "frontend/.eslintrc.js" ] || [ -f "frontend/.eslintrc.cjs" ] || [ -f "frontend/.eslintrc.json" ] || [ -f "frontend/eslint.config.js" ] || [ -f "frontend/eslint.config.mjs" ]; then
    npm --prefix frontend run lint
  else
    echo "[pre-push] Skipping frontend lint (no ESLint config found)."
  fi
  npm --prefix frontend run build
fi

echo "[pre-push] All checks passed."
exit 0
