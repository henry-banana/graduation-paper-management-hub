# Local and deployment compose variables

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=3000
REDIS_PORT=6379

# Runtime API endpoint for frontend container
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# GHCR image references for production compose
BACKEND_IMAGE=ghcr.io/your-org/graduation-paper-management-hub-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/graduation-paper-management-hub-frontend:latest

# Remote server app directories used by CD workflow
STAGING_APP_DIR=/opt/graduation-paper-management-hub
PRODUCTION_APP_DIR=/opt/graduation-paper-management-hub
